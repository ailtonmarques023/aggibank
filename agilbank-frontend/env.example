# API Configuration
# Com onboarding cookie (VITE_ONBOARDING_APPLICATION_ENABLED=true):
#   Vercel produção → use /api (same-origin; rewrite em vercel.json → Railway).
#   Dev local → /api com proxy Vite (vite.config.js) OU URL Railway com CORS.
# Sem onboarding cookie, URL Railway direta também funciona para JWT.
VITE_API_URL=/api

# App Configuration
VITE_APP_NAME=AgilBank
VITE_APP_VERSION=1.0.0

# Development
VITE_DEBUG=true

# Abertura de conta via proposta temporária (cookie). false = fluxo legado /auth/register
VITE_ONBOARDING_APPLICATION_ENABLED=false
