# API Configuration
# OBRIGATÓRIO em build de produção: URL do backend Railway terminando em /api.
# NUNCA use a URL do front na Vercel (ex.: https://aggibank.vercel.app/api) — isso não é a API.
# Se omitir em produção, o código usa fallback para o Railway público do projeto.
VITE_API_URL=https://aggibank-production.up.railway.app/api

# App Configuration
VITE_APP_NAME=AgilBank
VITE_APP_VERSION=1.0.0

# Development
VITE_DEBUG=true
