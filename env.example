# Servidor
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Banco de dados PostgreSQL
# Exemplo Railway/Neon/Supabase:
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Autenticacao
JWT_SECRET="troque-por-uma-chave-grande-e-segura"
JWT_REFRESH_SECRET="troque-por-outra-chave-grande-e-segura"
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Redis opcional
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
# Quando REDIS_URL estiver definido, backend usa Redis para brute force e metricas distribuidas.

# E-mail (verificação de conta, reset de senha, etc.)
#
# Produção (Railway): Resend é o caminho oficial — defina RESEND_API_KEY + EMAIL_FROM (domínio verificado no Resend).
#   RESEND_API_KEY=re_...
#   EMAIL_FROM=onboarding@seudominio.com
#   EMAIL_FROM_NAME=AgilBank
#   FRONTEND_URL=https://aggibank.vercel.app
#
# SMTP/Nodemailer é legado: em NODE_ENV=production só é usado se ALLOW_EMAIL_SMTP_FALLBACK=true (e rede permitir saída 587).
# Fora de produção, SMTP permanece permitido por padrão para desenvolvimento local.
#
# ALLOW_EMAIL_SMTP_FALLBACK=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
#
# Sem provedor configurado: POST /api/auth/resend-verification-email retorna 503 com code EMAIL_PROVIDER_NOT_CONFIGURED.
#
# npm run email:templates-demo — passar e-mail de teste na linha de comando.
RESEND_API_KEY=
ALLOW_EMAIL_SMTP_FALLBACK=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=AgilBank
# URL do front onde existem /banco/confirmar-email.html e reset (links nos e-mails)
FRONTEND_URL=http://127.0.0.1:5173

# Upload opcional
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Pagamentos/PIX em modo demo
PIX_PROVIDER=demo
GERENCIANET_CLIENT_ID=
GERENCIANET_CLIENT_SECRET=
GERENCIANET_SANDBOX=true

# Monitoramento opcional
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_WINDOW_MS=900000
AUTH_BLOCK_DURATION_MS=900000
OPS_METRICS_TTL_SECONDS=86400

# CORS
# Em producao, lista separada por virgula (obrigatorio para browser chamar a API).
# Tambem e possivel usar FRONTEND_URL: a origem dela e acrescentada automaticamente.
# Ex.: CORS_ORIGIN=https://app.agilbank.com,http://127.0.0.1:5173
# Producao Vercel + dev local: CORS_ORIGIN=https://aggibank.vercel.app,http://127.0.0.1:5173,http://localhost:5173
# FRONTEND_URL=https://aggibank.vercel.app
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Chaves internas (nao expor no frontend)
OPS_METRICS_INTERNAL_KEY=
CARD_APPROVAL_INTERNAL_KEY=
