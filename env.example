# Servidor
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Banco de dados PostgreSQL
# Exemplo Railway/Neon/Supabase:
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Autenticacao
JWT_SECRET="troque-por-uma-chave-grande-e-segura"
JWT_REFRESH_SECRET="troque-por-outra-chave-grande-e-segura"
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Redis opcional
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
# Quando REDIS_URL estiver definido, backend usa Redis para brute force e metricas distribuidas.

# Proposta temporária de abertura de conta (F1 — backend aditivo; Register legado inalterado quando false)
ONBOARDING_APPLICATION_ENABLED=false
# Envio único multipart no Register (sem cookie de proposta). false = fluxo cookie ou legado.
ONBOARDING_LINEAR_SUBMIT_ENABLED=false
# ONBOARDING_TOKEN_HMAC_SECRET=chave-separada-recomendada
# ONBOARDING_TOKEN_TTL_SECONDS=86400
# ONBOARDING_APPLICATION_EXPIRES_DAYS=7

# E-mail (verificação de conta, reset de senha, etc.)
#
# Produção (Railway): Resend é o caminho oficial — defina RESEND_API_KEY + EMAIL_FROM (domínio verificado no Resend).
#   RESEND_API_KEY=re_...
#   EMAIL_FROM=onboarding@seudominio.com
#   EMAIL_FROM_NAME=AgilBank
#   FRONTEND_URL=https://aggibank.vercel.app
#
# SMTP/Nodemailer é legado: em NODE_ENV=production só é usado se ALLOW_EMAIL_SMTP_FALLBACK=true (e rede permitir saída 587).
# Fora de produção, SMTP permanece permitido por padrão para desenvolvimento local.
#
# ALLOW_EMAIL_SMTP_FALLBACK=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
#
# Sem provedor configurado: POST /api/auth/resend-verification-email retorna 503 com code EMAIL_PROVIDER_NOT_CONFIGURED.
#
# npm run email:templates-demo — passar e-mail de teste na linha de comando.
RESEND_API_KEY=
ALLOW_EMAIL_SMTP_FALLBACK=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=AgilBank
# URL do front onde existem /banco/confirmar-email.html e reset (links nos e-mails)
FRONTEND_URL=http://127.0.0.1:5173

# Upload opcional
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Pagamentos/PIX em modo demo (legado / outros fluxos)
PIX_PROVIDER=demo
# Fase Q — PSP usado em POST /api/charges/:id/pix (substituível). Valores futuros alinhados a pixProviderRegistry.
PIX_CHARGE_PROVIDER=EFI
GERENCIANET_CLIENT_ID=
GERENCIANET_CLIENT_SECRET=
GERENCIANET_SANDBOX=true

# Efí / Gerencianet — Pix Cob (Fase N sandbox / N-PROD produção controlada).
# Certificado .p12 do integrador (homologação ou produção). Não commitar o arquivo real.
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERTIFICATE_PATH=
# Alternativa ao path: conteúdo .p12 em base64 (ex.: Railway secret multiline)
EFI_CERTIFICATE_BASE64=
EFI_CERTIFICATE_PASS=
# Chave Pix recebedora cadastrada na conta Efí (EVP ou tipo permitido)
EFI_PIX_KEY=
# sandbox | production — em production exige também EFI_PIX_ENABLE_PRODUCTION=true (sem webhook/settlement nesta fase)
EFI_ENVIRONMENT=sandbox
# true = permite host produção Efí Pix (pix.api.efipay.com.br). Sem isso, production não emite cob.
EFI_PIX_ENABLE_PRODUCTION=
# Opcional em produção: teto do valor "original" da cob (ex. 10.00). Vazio = sem limite no código.
EFI_PIX_PRODUCTION_MAX_ORIGINAL=
# Expiração da cob imediata em segundos (padrão 3600)
EFI_PIX_EXPIRATION_SECONDS=3600
# URL pública do webhook (cadastro na Efí — fase webhook futura)
EFI_WEBHOOK_URL=
# HMAC opcional na URL quando usar skip-mTLS (ver doc Efí)
EFI_WEBHOOK_SECRET=
# Chave interna para POST /api/internal/efi/pix/webhook (header x-internal-key). Não expor no frontend.
EFI_PIX_WEBHOOK_INTERNAL_KEY=
# Token na query efiwk= na URL cadastrada na Efí (a Efí não envia header customizado no POST recebido).
# Cadastro recomendado (Fase O.2): .../api/internal/efi/pix/webhook/pix?ignorar=&efiwk=<token>
EFI_PIX_WEBHOOK_CALLBACK_TOKEN=
# PUT/GET webhook na API Efí: enviar x-skip-mtls-checking (doc Efí homologação). Padrão true.
EFI_PIX_WEBHOOK_SKIP_MTLS=true
# Opcional: base pública para script efi:o1-webhook (padrão Railway produção AgilBank).
# EFI_O1_WEBHOOK_BASE_URL=https://aggibank-production.up.railway.app
#
# Fase R — conciliação de Pix já pago na Efí sem emitir nova cobrança (operacional; não é rota pública).
# npm run efi:r:reconcile -- --dry-run
# railway run npm run efi:r:reconcile -- --dry-run --txid=SEU_TXID
# Escopos Efí: cob.read, pix.read (além de credenciais/certificado já usados na emissão).

# Fase S.4 — conciliação financeira (tarifa/líquido) via Extrato de Conciliação API Pix (`/v2/gn/relatorios/*`).
# npm run efi:s4:reconcile-fees -- --dry-run
# npm run efi:s4:reconcile-fees -- --dry-run --date=2026-05-11
# npm run efi:s4:reconcile-fees -- --dry-run --txid=SEU_TXID
# Produção + escopos Efí: gn.reports.write e gn.reports.read. Padrão: dry-run (sem --apply não grava).

# Monitoramento opcional
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_WINDOW_MS=900000
AUTH_BLOCK_DURATION_MS=900000
OPS_METRICS_TTL_SECONDS=86400

# CORS
# Em producao, lista separada por virgula (obrigatorio para browser chamar a API).
# Tambem e possivel usar FRONTEND_URL: a origem dela e acrescentada automaticamente.
# Ex.: CORS_ORIGIN=https://app.agilbank.com,http://127.0.0.1:5173
# Producao Vercel + dev local: CORS_ORIGIN=https://aggibank.vercel.app,http://127.0.0.1:5173,http://localhost:5173
# FRONTEND_URL=https://aggibank.vercel.app
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Chaves internas (nao expor no frontend)
OPS_METRICS_INTERNAL_KEY=
# Crédito de saldo disponível só para homologação/staging (bloqueado se NODE_ENV=production)
OPS_CREDIT_INTERNAL_KEY=
#
# Fase K.1 — validação operacional em staging (script npm run validate:k1-ops-credit)
# K1_STAGING_BASE_URL=https://seu-api-staging.example.com
# K1_I_CONFIRM_STAGING_NOT_PRODUCTION=yes
# K1_TEST_EMAIL=
# K1_TEST_PASSWORD=
# K1_REF_OPERADOR=homologacao
# K1_IDEMPOTENCY_KEY=opcional
CARD_APPROVAL_INTERNAL_KEY=
