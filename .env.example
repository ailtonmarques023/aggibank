# =============================================================================
# AgilBank Backend — exemplo de variáveis (copiar para `.env`; não usar segredos reais aqui).
# =============================================================================

NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/agilbank?schema=public"
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# KYC / identidade — armazenamento S3-compatível (Fatia 4 — infra apenas)
#
# IMPORTANTE:
# - `isVerificado` continua apenas e-mail; este bloco não altera cadastro atual.
# - Bucket deve ser **privado** (sem acesso público anônimo).
# - Não usar CPF/e-mail no objectKey — o código gera apenas identity/{submissionId}/{artifactId}
# -----------------------------------------------------------------------------
# Liga presign/uso real do storage nos endpoints Fatia 6: GET `/api/me/kyc-status`,
# POST `/api/me/kyc/presign` (precisa também bucket + credenciais). Demais fluxos continuam apenas leitura/DB quando false.
FEATURE_KYC_ENABLED=false
# Exige FACE_VIDEO no submit/KYC status (default false — ADR-KYC-001). Não ligar em produção até app com captura de vídeo.
FEATURE_KYC_REQUIRE_FACE_VIDEO=false
# Futuro middleware de autorização produto / gates Pix-cartão-crédito (somente quando implementado).
FEATURE_GATE_IDENTITY_APPROVED=false
# Motor automático de decisão KYC (Fatia 1 — default off; shadow apenas audita recomendação).
FEATURE_KYC_AUTO_DECISION_ENABLED=false
FEATURE_KYC_AUTO_DECISION_SHADOW=true
# Janela (dias) para contar REJECTED / RESUBMISSION_REQUIRED como rejeição recente no motor.
# KYC_AUTO_DECISION_REJECT_LOOKBACK_DAYS=90

# Provedor informativo: s3_compat | aws | r2 | minio | b2 (client SDK é sempre S3 API).
KYC_STORAGE_PROVIDER=s3_compat
KYC_STORAGE_BUCKET=
KYC_STORAGE_REGION=us-east-1
# Opcional Cloudflare R2 / MinIO: URL do endpoint HTTPS (sem barra final desnecessária).
KYC_STORAGE_ENDPOINT=

KYC_STORAGE_ACCESS_KEY_ID=
KYC_STORAGE_SECRET_ACCESS_KEY=
# Opcional prefixo antes de identity/ … (somente caracteres permitidos pelo serviço; sem PII).
# KYC_STORAGE_OBJECT_KEY_PREFIX=staging/

# R2 ou MinIO em geral exigem path-style; omitir usa heurística quando ENDPOINT casa R2/minio localhost.
# KYC_STORAGE_FORCE_PATH_STYLE=true

# TTL URLs assinadas (PUT/GET) em segundos (30–3600).
KYC_PRESIGN_TTL_SECONDS=900
# Limite de upload esperado antes de gravar artefato (bytes). Padrão 15 MiB no código se omitido.
# KYC_UPLOAD_MAX_BYTES=15728640
# Limite de upload para FACE_VIDEO (bytes). Padrão 30 MiB no código se omitido (ADR-KYC-001).
# KYC_VIDEO_UPLOAD_MAX_BYTES=31457280

# Chave interna para operações MVP admin KYC quando rotas `/internal/kyc/*` existirem.
INTERNAL_KYC_KEY=

# -----------------------------------------------------------------------------
# Proposta temporária de abertura de conta (AccountApplication F1+)
# -----------------------------------------------------------------------------
# Liga POST/GET /api/onboarding/* (default false — app legado /register inalterado).
ONBOARDING_APPLICATION_ENABLED=false
# Envio único multipart no Register (sem cookie de proposta). false = fluxo cookie ou legado.
ONBOARDING_LINEAR_SUBMIT_ENABLED=false
# TTL da sessão HTTP-only agilbank_onboarding_session (segundos). Padrão 1800 (30 min).
# ONBOARDING_SESSION_MAX_AGE_SECONDS=1800
# HMAC do segredo de sessão (não logar valor da cookie).
# ONBOARDING_SESSION_HMAC_SECRET=
# Legado F1 — token por header (migração); não retornado no JSON na fatia cookie.
# ONBOARDING_TOKEN_TTL_SECONDS=86400
# ONBOARDING_APPLICATION_EXPIRES_DAYS=7
# ONBOARDING_TOKEN_HMAC_SECRET=
# Forçar Secure na cookie de onboarding em dev (ex.: teste cross-origin local).
# ONBOARDING_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Promoção automática de cobranças (Fatia 1+ — modelagem/quote; endpoints futuros)
# -----------------------------------------------------------------------------
# Liga GET /api/charges/promotions/current e POST .../promotions/:id/pix (quando implementados).
# Fatia 1: apenas schema + chargePromotionService (sem rotas públicas).
FEATURE_CHARGE_PROMOTIONS_ENABLED=false
# Emissão de Pix promocional agrupado (Fatia 3+). Não habilitar em produção antes do settlement agrupado (Fatia 4).
FEATURE_CHARGE_PROMOTION_PIX_ENABLED=false
# Settlement agrupado no webhook quando Pix promocional é pago (Fatia 4). Manter false até validação em staging.
FEATURE_CHARGE_PROMOTION_SETTLEMENT_ENABLED=false
# TTL da promoção ativa em segundos (expiresAt = now + TTL). Padrão 120.
CHARGE_PROMOTION_TTL_SECONDS=120
