{
  "name": "agilbank-backend",
  "version": "1.0.0",
  "description": "Backend do AgilBank - Aplicativo bancário digital",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "frontend": "node -e \"const express=require('express');const path=require('path');const app=express();app.use(express.static('.'));app.get('/',(req,res)=>res.sendFile(path.join(__dirname,'index.html')));app.listen(3000,()=>console.log('Frontend: http://localhost:3000'));\"",
    "build": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node src/scripts/seed.js",
    "email:templates-demo": "node src/scripts/sendEmailTemplatesSample.js",
    "test": "jest",
    "validate:k1-ops-credit": "node scripts/validate-k1-ops-credit-staging.js",
    "efi:o1-webhook": "node scripts/efi-o1-register-pix-webhook.js",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "agilbank",
    "banking",
    "fintech",
    "api",
    "nodejs"
  ],
  "author": "AgilBank Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.4",
    "redis": "^4.6.12",
    "sharp": "^0.33.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^6.16.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
