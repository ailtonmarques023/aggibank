generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  nomeCompleto        String
  email               String                @unique
  cpf                 String                @unique
  telefone            String?
  dataNascimento      DateTime
  senha               String
  saldoAtual          Decimal               @default(0) @db.Decimal(10, 2)
  saldoBloqueado      Decimal               @default(0) @db.Decimal(10, 2)
  limiteCartao        Decimal?              @db.Decimal(10, 2)
  limitePixDiario     Decimal?              @db.Decimal(10, 2)
  limitePixMensal     Decimal?              @db.Decimal(10, 2)
  scoreCredito        Int                   @default(0)
  numeroConta         String?               @unique
  digitoConta         String?
  agencia             String?
  isAtivo             Boolean               @default(true)
  isVerificado        Boolean               @default(false)
  tokenVerificacao    String?
  dataVerificacao     DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  afiliacoes          afiliacoes[]
  boletos             Boleto[]
  campanhas           campanhas[]
  cartoes             Cartao[]
  cartoesVirtuais     CartaoVirtual[]
  chavesPix           ChavePix[]
  configuracoes       ConfiguracoesUsuario?
  dadosProfissionais  DadosProfissionais?
  emprestimos         Emprestimo[]
  loanInsuranceCharges LoanInsuranceCharge[]
  endereco            Endereco?
  gamificacao_usuario gamificacao_usuario?
  movimentacoes       Movimentacao[]
  notificacoes        Notificacao[]
  pagamentos          Pagamento[]
  tokens              Token[]
  transacoesPix       TransacaoPix[]
  auditLogs           AuditLog[]
  cardShipments       CardShipment[]
  cardShipmentEvents  CardShipmentEvent[]
  pixCobrancas        PixCobranca[]

  @@map("usuarios")
}

model Endereco {
  id          String   @id @default(cuid())
  userId      String   @unique
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  pais        String   @default("Brasil")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("enderecos")
}

model DadosProfissionais {
  id            String   @id @default(cuid())
  userId        String   @unique
  profissao     String
  empresa       String?
  rendaMensal   Decimal? @db.Decimal(10, 2)
  tempoTrabalho String?
  cargo         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dados_profissionais")
}

model ConfiguracoesUsuario {
  id                String   @id @default(cuid())
  userId            String   @unique
  notificacoesEmail Boolean  @default(true)
  notificacoesSms   Boolean  @default(true)
  notificacoesPush  Boolean  @default(true)
  temaInterface     String   @default("claro")
  idioma            String   @default("pt-BR")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("configuracoes_usuario")
}

model Cartao {
  id                  String    @id @default(cuid())
  userId              String
  maskedNumber        String
  last4               String    @db.VarChar(4)
  validade            String
  bandeira            String
  cardToken           String?   @unique
  limite              Decimal   @db.Decimal(10, 2)
  saldoUtilizado      Decimal   @default(0) @db.Decimal(10, 2)
  status              String    @default("pendente")
  tipo                String    @default("credito")
  dataSolicitacao     DateTime  @default(now())
  dataAprovacao       DateTime?
  dadosSolicitacao    Json?
  lgpdConsentAt       DateTime?
  lgpdConsentVersion  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartoesVirtuais     CartaoVirtual[]
  shipments           CardShipment[]

  @@map("cartoes")
}

model CardShipment {
  id                   String               @id @default(cuid())
  cardId               String
  userId               String
  status               ShipmentStatus       @default(AGUARDANDO_COBRANCA)
  shippingFeeAmount    Decimal              @default(39.90) @db.Decimal(10, 2)
  shippingFeeStatus    ShipmentFeeStatus    @default(PENDENTE)
  shippingFeeMovementId String?
  carrierCode          String?
  carrierName          String?
  trackingCode         String?
  trackingUrl          String?
  estimatedDeliveryAt  DateTime?
  postedAt             DateTime?
  deliveredAt          DateTime?
  returnedAt           DateTime?
  deliveryAttempts     Int                  @default(0)
  isSecondIssue        Boolean              @default(false)
  originShipmentId     String?
  idempotencyKeyCharge String?              @unique
  addressSnapshot      Json
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  card                 Cartao               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingFeeMovement  Movimentacao?        @relation("ShipmentFeeMovement", fields: [shippingFeeMovementId], references: [id], onDelete: SetNull)
  originShipment       CardShipment?        @relation("ShipmentReissue", fields: [originShipmentId], references: [id], onDelete: SetNull)
  reissues             CardShipment[]       @relation("ShipmentReissue")
  events               CardShipmentEvent[]

  @@index([cardId])
  @@index([userId])
  @@index([trackingCode])
  @@map("card_shipments")
}

model CardShipmentEvent {
  id              String             @id @default(cuid())
  shipmentId      String
  userId          String?
  eventType       ShipmentEventType
  shipmentStatus  ShipmentStatus?
  eventAt         DateTime           @default(now())
  description     String?
  providerPayload Json?
  createdByType   ShipmentActorType  @default(SYSTEM)
  createdById     String?
  createdAt       DateTime           @default(now())
  shipment        CardShipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shipmentId, eventAt])
  @@map("card_shipment_events")
}

model CartaoVirtual {
  id            String   @id @default(cuid())
  cartaoId      String
  userId        String
  maskedNumber  String
  last4         String   @db.VarChar(4)
  validade      String
  bandeira      String
  cardToken     String   @unique
  cvvHash       String
  status        String   @default("ativo")
  dataBloqueio  DateTime?
  dataCancelado DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cartao        Cartao   @relation(fields: [cartaoId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cartaoId])
  @@index([userId])
  @@map("cartoes_virtuais")
}

model Emprestimo {
  id                     String    @id @default(cuid())
  userId                 String
  valorSolicitado        Decimal   @db.Decimal(10, 2)
  valorAprovado          Decimal?  @db.Decimal(10, 2)
  prazoMeses             Int
  taxaJuros              Decimal   @db.Decimal(5, 2)
  valorParcela           Decimal?  @db.Decimal(10, 2)
  status                 String    @default("pendente")
  insuranceSelected      Boolean   @default(false)
  insuranceAmount        Decimal?  @db.Decimal(10, 2)
  insuranceTermsAccepted Boolean   @default(false)
  fundsStatus            String?
  blockedAmount          Decimal?  @db.Decimal(10, 2)
  guaranteeStatus        String    @default("not_required")
  insuranceChargeStatus  String?
  dataSolicitacao        DateTime  @default(now())
  dataAprovacao          DateTime?
  dataQuitacao           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  insuranceCharge        LoanInsuranceCharge?

  @@map("emprestimos")
}

model LoanInsuranceCharge {
  id               String    @id @default(cuid())
  loanId           String    @unique
  userId           String
  amount           Decimal   @db.Decimal(10, 2)
  status           String    @default("pendente")
  idempotencyKey   String?   @unique
  createdAt        DateTime  @default(now())
  paidAt           DateTime?
  emprestimo       Emprestimo @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loan_insurance_charges")
}

model Movimentacao {
  id               String   @id @default(cuid())
  userId           String
  tipo             String
  descricao        String
  valor            Decimal  @db.Decimal(10, 2)
  saldoAnterior    Decimal  @db.Decimal(10, 2)
  saldoAtual       Decimal  @db.Decimal(10, 2)
  categoria        String?
  referenceType    String?
  referenceId      String?
  idempotencyKey   String?  @unique
  dataMovimentacao DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipmentFees     CardShipment[] @relation("ShipmentFeeMovement")

  @@map("movimentacoes")
}

enum ShipmentStatus {
  AGUARDANDO_COBRANCA
  COBRANCA_CONFIRMADA
  EM_PRODUCAO
  POSTADO
  EM_TRANSITO
  SAIU_PARA_ENTREGA
  ENTREGUE
  FALHA_ENTREGA
  DEVOLVIDO
}

enum ShipmentFeeStatus {
  PENDENTE
  DEBITADO
  RECUSADO
}

enum ShipmentEventType {
  SHIPMENT_CREATED
  FRETE_COBRADO
  FRETE_RECUSADO
  STATUS_ATUALIZADO
}

enum ShipmentActorType {
  SYSTEM
  USER
  INTERNAL_API
}

model Notificacao {
  id        String    @id @default(cuid())
  userId    String
  titulo    String
  mensagem  String
  tipo      String
  isLida    Boolean   @default(false)
  dataEnvio DateTime  @default(now())
  createdAt DateTime  @default(now())
  metadata  Json?
  readAt    DateTime?
  dedupeKey String?   @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificacoes")
}

model TransacaoPix {
  id                 String   @id @default(cuid())
  userId             String
  chavePix           String
  valor              Decimal  @db.Decimal(10, 2)
  descricao          String?
  status             String   @default("pendente")
  tipo               String
  remetente          String?
  destinatario       String?
  idempotencyKey     String?  @unique
  providerReference  String?
  environment        String   @default("demo")
  dataTransacao      DateTime @default(now())
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transacoes_pix")
}

model ChavePix {
  id           String    @id @default(cuid())
  userId       String
  tipo         String
  valor        String    @unique
  status       String    @default("pendente")
  dataCriacao  DateTime  @default(now())
  dataAtivacao DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chaves_pix")
}

model Boleto {
  id                String    @id @default(cuid())
  userId            String
  codigoBarras      String    @unique
  valor             Decimal   @db.Decimal(10, 2)
  dataVencimento    DateTime
  descricao         String
  beneficiario      String
  status            String    @default("pendente")
  dataPagamento     DateTime?
  createdAt         DateTime  @default(now())
  protocolo         String?   @unique
  cpfOuCnpj         String?
  solicitacaoTipo   String?
  solicitacaoId     String?
  pixCopiaECola     String?
  qrCodePix         String?
  pixReceiverKey    String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([solicitacaoTipo, solicitacaoId])
  @@map("boletos")
}

model Pagamento {
  id                 String    @id @default(cuid())
  userId             String
  valor              Decimal   @db.Decimal(10, 2)
  tipo               String
  status             String    @default("pendente")
  chavePix           String?
  codigoBarras       String?
  idempotencyKey     String?   @unique
  providerReference  String?
  environment        String    @default("demo")
  dataPagamento      DateTime?
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pagamentos")
}

model Token {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  tipo       String
  expiraEm   DateTime
  isAtivo    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model afiliacoes {
  id         String    @id
  userId     String
  afiliadoId String
  comissao   Decimal   @db.Decimal(5, 2)
  status     String    @default("ativa")
  dataInicio DateTime  @default(now())
  dataFim    DateTime?
  createdAt  DateTime  @default(now())
  usuarios   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model campanhas {
  id         String    @id
  userId     String
  nome       String
  descricao  String
  orcamento  Decimal   @db.Decimal(10, 2)
  status     String    @default("ativa")
  dataInicio DateTime  @default(now())
  dataFim    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  usuarios   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model gamificacao_usuario {
  id        String   @id
  userId    String   @unique
  xp        Int      @default(0)
  nivel     Int      @default(1)
  streak    Int      @default(0)
  badges    String[] @default([])
  ranking   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime
  usuarios  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

/// Cobrança Pix emitida por um PSP (Fase N emissão; Fase O webhook; Fase Q: campo `provider`).
model PixCobranca {
  id                 String             @id @default(cuid())
  userId             String
  linkedEntityType   String
  linkedEntityId     String
  amount             Decimal            @db.Decimal(10, 2)
  /// PSP emissor (ex.: EFI). Taxas líquidas/brutas: futuro quando a API do PSP informar valores confiáveis.
  provider           String             @default("EFI")
  status             String             @default("ATIVA")
  txid               String             @unique
  endToEndId         String?            @unique
  providerReference  String?
  pixCopiaECola      String?            @db.Text
  qrCodePix          String?            @db.Text
  expiresAt          DateTime
  paidAt             DateTime?
  idempotencyKey     String             @unique
  rawProviderPayload Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEvents      PixWebhookEvent[]

  @@index([userId, linkedEntityType, linkedEntityId])
  @@map("pix_cobrancas")
}

/// Evento recebido do webhook Pix (PSP; hoje Efí). Idempotência por idempotencyKey (ex.: endToEndId).
model PixWebhookEvent {
  id                 String       @id @default(cuid())
  idempotencyKey     String       @unique
  txid               String?
  endToEndId         String?
  amountReceived     String?
  processingResult   String
  pixCobrancaId      String?
  metadata           Json?
  createdAt          DateTime     @default(now())
  pixCobranca        PixCobranca? @relation(fields: [pixCobrancaId], references: [id], onDelete: SetNull)

  @@index([txid])
  @@index([endToEndId])
  @@index([pixCobrancaId])
  @@map("pix_webhook_events")
}
