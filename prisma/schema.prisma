generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  nomeCompleto        String
  email               String                @unique
  cpf                 String                @unique
  telefone            String?
  dataNascimento      DateTime
  senha               String
  saldoAtual          Decimal               @default(0) @db.Decimal(10, 2)
  saldoBloqueado      Decimal               @default(0) @db.Decimal(10, 2)
  limiteCartao        Decimal?              @db.Decimal(10, 2)
  limitePixDiario     Decimal?              @db.Decimal(10, 2)
  limitePixMensal     Decimal?              @db.Decimal(10, 2)
  scoreCredito        Int                   @default(0)
  numeroConta         String?               @unique
  digitoConta         String?
  agencia             String?
  isAtivo             Boolean               @default(true)
  isVerificado        Boolean               @default(false)
  tokenVerificacao    String?
  dataVerificacao     DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  afiliacoes          afiliacoes[]
  boletos             Boleto[]
  campanhas           campanhas[]
  cartoes             Cartao[]
  cartoesVirtuais     CartaoVirtual[]
  chavesPix           ChavePix[]
  configuracoes       ConfiguracoesUsuario?
  dadosProfissionais  DadosProfissionais?
  emprestimos         Emprestimo[]
  loanInsuranceCharges LoanInsuranceCharge[]
  endereco            Endereco?
  gamificacao_usuario gamificacao_usuario?
  movimentacoes       Movimentacao[]
  notificacoes        Notificacao[]
  pagamentos          Pagamento[]
  tokens              Token[]
  transacoesPix       TransacaoPix[]
  auditLogs           AuditLog[]
  cardShipments       CardShipment[]
  cardShipmentEvents  CardShipmentEvent[]
  pixCobrancas        PixCobranca[]
  accountDeposits     AccountDeposit[]
  internalTransfersFrom InternalTransfer[] @relation("InternalTransferFrom")
  internalTransfersTo   InternalTransfer[] @relation("InternalTransferTo")
  referralCode          ReferralCode?
  referralsMade         Referral[]         @relation("ReferralReferrer")
  referredBy            Referral?          @relation("ReferralReferred")
  referralRewards       ReferralReward[]
  identitySubmissions   IdentitySubmission[] @relation("UserIdentitySubmissions")
  /// Cópia de leitura para gates/admin; fonte jurídica do fluxo: IdentitySubmission.status
  identityReviewStatus     IdentityReviewStatus @default(NONE)
  identityApprovedAt       DateTime?
  lastIdentitySubmissionId String?               @unique
  lastIdentitySubmission   IdentitySubmission?   @relation("UserLastIdentitySubmission", fields: [lastIdentitySubmissionId], references: [id], onDelete: SetNull)

  @@map("usuarios")
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("referral_codes")
}

model Referral {
  id              String    @id @default(cuid())
  referrerUserId  String
  referredUserId  String    @unique
  referralCode    String
  status          String    @default("PENDENTE")
  qualifiedAt     DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  referrer        User      @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred        User      @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId, status])
  @@index([referralCode])
  @@map("referrals")
}

model ReferralReward {
  id                String        @id @default(cuid())
  userId            String
  cycleNumber       Int
  requiredCount     Int           @default(10)
  amount            Decimal       @db.Decimal(10, 2)
  status            String        @default("BLOQUEADO")
  blockedMovementId String?
  releasedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockedMovement   Movimentacao? @relation("ReferralRewardBlockedMovement", fields: [blockedMovementId], references: [id], onDelete: SetNull)

  @@unique([userId, cycleNumber])
  @@index([userId, status])
  @@map("referral_rewards")
}

/// Transferência interna entre contas AgilBank (Fase W). Ledger obrigatório; sem Pix/TED.
model InternalTransfer {
  id               String    @id @default(cuid())
  fromUserId       String
  toUserId         String
  amount           Decimal   @db.Decimal(10, 2)
  /// PENDENTE | CONCLUIDA | FALHOU | CANCELADA
  status           String    @default("PENDENTE")
  idempotencyKey   String
  debitMovementId  String?
  creditMovementId String?
  description      String?
  failureReason    String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  failedAt         DateTime?
  fromUser         User      @relation("InternalTransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser           User      @relation("InternalTransferTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, idempotencyKey])
  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@map("internal_transfers")
}

/// Depósito em conta via Pix (valor escolhido pelo titular; crédito só após confirmação PSP — Fase U).
model AccountDeposit {
  id                   String       @id @default(cuid())
  userId               String
  amount               Decimal      @db.Decimal(10, 2)
  /// PENDENTE | PIX_GERADO | PAGO | CREDITADO | CANCELADO | EXPIRADO
  status               String       @default("PENDENTE")
  provider             String       @default("EFI")
  pixCobrancaId        String?      @unique
  creditedMovementId String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  paidAt               DateTime?
  creditedAt           DateTime?
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pixCobranca          PixCobranca? @relation(fields: [pixCobrancaId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("account_deposits")
}

model Endereco {
  id          String   @id @default(cuid())
  userId      String   @unique
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  pais        String   @default("Brasil")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("enderecos")
}

model DadosProfissionais {
  id            String   @id @default(cuid())
  userId        String   @unique
  profissao     String
  empresa       String?
  rendaMensal   Decimal? @db.Decimal(10, 2)
  tempoTrabalho String?
  cargo         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dados_profissionais")
}

model ConfiguracoesUsuario {
  id                String   @id @default(cuid())
  userId            String   @unique
  notificacoesEmail Boolean  @default(true)
  notificacoesSms   Boolean  @default(true)
  notificacoesPush  Boolean  @default(true)
  temaInterface     String   @default("claro")
  idioma            String   @default("pt-BR")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("configuracoes_usuario")
}

model Cartao {
  id                  String    @id @default(cuid())
  userId              String
  maskedNumber        String
  last4               String    @db.VarChar(4)
  validade            String
  bandeira            String
  cardToken           String?   @unique
  limite              Decimal   @db.Decimal(10, 2)
  saldoUtilizado      Decimal   @default(0) @db.Decimal(10, 2)
  status              String    @default("pendente")
  tipo                String    @default("credito")
  dataSolicitacao     DateTime  @default(now())
  dataAprovacao       DateTime?
  dadosSolicitacao    Json?
  lgpdConsentAt       DateTime?
  lgpdConsentVersion  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartoesVirtuais     CartaoVirtual[]
  shipments           CardShipment[]

  @@map("cartoes")
}

model CardShipment {
  id                   String               @id @default(cuid())
  cardId               String
  userId               String
  status               ShipmentStatus       @default(AGUARDANDO_COBRANCA)
  shippingFeeAmount    Decimal              @default(39.90) @db.Decimal(10, 2)
  shippingFeeStatus    ShipmentFeeStatus    @default(PENDENTE)
  shippingFeeMovementId String?
  carrierCode          String?
  carrierName          String?
  trackingCode         String?
  trackingUrl          String?
  estimatedDeliveryAt  DateTime?
  postedAt             DateTime?
  deliveredAt          DateTime?
  returnedAt           DateTime?
  deliveryAttempts     Int                  @default(0)
  isSecondIssue        Boolean              @default(false)
  originShipmentId     String?
  idempotencyKeyCharge String?              @unique
  addressSnapshot      Json
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  card                 Cartao               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingFeeMovement  Movimentacao?        @relation("ShipmentFeeMovement", fields: [shippingFeeMovementId], references: [id], onDelete: SetNull)
  originShipment       CardShipment?        @relation("ShipmentReissue", fields: [originShipmentId], references: [id], onDelete: SetNull)
  reissues             CardShipment[]       @relation("ShipmentReissue")
  events               CardShipmentEvent[]

  @@index([cardId])
  @@index([userId])
  @@index([trackingCode])
  @@map("card_shipments")
}

model CardShipmentEvent {
  id              String             @id @default(cuid())
  shipmentId      String
  userId          String?
  eventType       ShipmentEventType
  shipmentStatus  ShipmentStatus?
  eventAt         DateTime           @default(now())
  description     String?
  providerPayload Json?
  createdByType   ShipmentActorType  @default(SYSTEM)
  createdById     String?
  createdAt       DateTime           @default(now())
  shipment        CardShipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shipmentId, eventAt])
  @@map("card_shipment_events")
}

model CartaoVirtual {
  id            String   @id @default(cuid())
  cartaoId      String
  userId        String
  maskedNumber  String
  last4         String   @db.VarChar(4)
  validade      String
  bandeira      String
  cardToken     String   @unique
  cvvHash       String
  status        String   @default("ativo")
  dataBloqueio  DateTime?
  dataCancelado DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cartao        Cartao   @relation(fields: [cartaoId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cartaoId])
  @@index([userId])
  @@map("cartoes_virtuais")
}

model Emprestimo {
  id                     String    @id @default(cuid())
  userId                 String
  valorSolicitado        Decimal   @db.Decimal(10, 2)
  valorAprovado          Decimal?  @db.Decimal(10, 2)
  prazoMeses             Int
  taxaJuros              Decimal   @db.Decimal(5, 2)
  valorParcela           Decimal?  @db.Decimal(10, 2)
  status                 String    @default("pendente")
  insuranceSelected      Boolean   @default(false)
  insuranceAmount        Decimal?  @db.Decimal(10, 2)
  insuranceTermsAccepted Boolean   @default(false)
  fundsStatus            String?
  blockedAmount          Decimal?  @db.Decimal(10, 2)
  guaranteeStatus        String    @default("not_required")
  insuranceChargeStatus  String?
  dataSolicitacao        DateTime  @default(now())
  dataAprovacao          DateTime?
  dataQuitacao           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  insuranceCharge        LoanInsuranceCharge?

  @@map("emprestimos")
}

model LoanInsuranceCharge {
  id               String    @id @default(cuid())
  loanId           String    @unique
  userId           String
  amount           Decimal   @db.Decimal(10, 2)
  status           String    @default("pendente")
  idempotencyKey   String?   @unique
  createdAt        DateTime  @default(now())
  paidAt           DateTime?
  emprestimo       Emprestimo @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loan_insurance_charges")
}

model Movimentacao {
  id               String   @id @default(cuid())
  userId           String
  tipo             String
  descricao        String
  valor            Decimal  @db.Decimal(10, 2)
  saldoAnterior    Decimal  @db.Decimal(10, 2)
  saldoAtual       Decimal  @db.Decimal(10, 2)
  categoria        String?
  referenceType    String?
  referenceId      String?
  idempotencyKey   String?  @unique
  dataMovimentacao DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipmentFees     CardShipment[]   @relation("ShipmentFeeMovement")
  referralRewards  ReferralReward[] @relation("ReferralRewardBlockedMovement")

  @@map("movimentacoes")
}

enum ShipmentStatus {
  AGUARDANDO_COBRANCA
  COBRANCA_CONFIRMADA
  EM_PRODUCAO
  POSTADO
  EM_TRANSITO
  SAIU_PARA_ENTREGA
  ENTREGUE
  FALHA_ENTREGA
  DEVOLVIDO
}

enum ShipmentFeeStatus {
  PENDENTE
  DEBITADO
  RECUSADO
}

enum ShipmentEventType {
  SHIPMENT_CREATED
  FRETE_COBRADO
  FRETE_RECUSADO
  STATUS_ATUALIZADO
}

enum ShipmentActorType {
  SYSTEM
  USER
  INTERNAL_API
}

model Notificacao {
  id        String    @id @default(cuid())
  userId    String
  titulo    String
  mensagem  String
  tipo      String
  isLida    Boolean   @default(false)
  dataEnvio DateTime  @default(now())
  createdAt DateTime  @default(now())
  metadata  Json?
  readAt    DateTime?
  dedupeKey String?   @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificacoes")
}

model TransacaoPix {
  id                 String   @id @default(cuid())
  userId             String
  chavePix           String
  valor              Decimal  @db.Decimal(10, 2)
  descricao          String?
  status             String   @default("pendente")
  tipo               String
  remetente          String?
  destinatario       String?
  idempotencyKey     String?  @unique
  providerReference  String?
  environment        String   @default("demo")
  dataTransacao      DateTime @default(now())
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transacoes_pix")
}

model ChavePix {
  id           String    @id @default(cuid())
  userId       String
  tipo         String
  valor        String    @unique
  status       String    @default("pendente")
  dataCriacao  DateTime  @default(now())
  dataAtivacao DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chaves_pix")
}

model Boleto {
  id                String    @id @default(cuid())
  userId            String
  codigoBarras      String    @unique
  valor             Decimal   @db.Decimal(10, 2)
  dataVencimento    DateTime
  descricao         String
  beneficiario      String
  status            String    @default("pendente")
  dataPagamento     DateTime?
  createdAt         DateTime  @default(now())
  protocolo         String?   @unique
  cpfOuCnpj         String?
  solicitacaoTipo   String?
  solicitacaoId     String?
  pixCopiaECola     String?
  qrCodePix         String?
  pixReceiverKey    String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([solicitacaoTipo, solicitacaoId])
  @@map("boletos")
}

model Pagamento {
  id                 String    @id @default(cuid())
  userId             String
  valor              Decimal   @db.Decimal(10, 2)
  tipo               String
  status             String    @default("pendente")
  chavePix           String?
  codigoBarras       String?
  idempotencyKey     String?   @unique
  providerReference  String?
  environment        String    @default("demo")
  dataPagamento      DateTime?
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pagamentos")
}

model Token {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  tipo       String
  expiraEm   DateTime
  isAtivo    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model afiliacoes {
  id         String    @id
  userId     String
  afiliadoId String
  comissao   Decimal   @db.Decimal(5, 2)
  status     String    @default("ativa")
  dataInicio DateTime  @default(now())
  dataFim    DateTime?
  createdAt  DateTime  @default(now())
  usuarios   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model campanhas {
  id         String    @id
  userId     String
  nome       String
  descricao  String
  orcamento  Decimal   @db.Decimal(10, 2)
  status     String    @default("ativa")
  dataInicio DateTime  @default(now())
  dataFim    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  usuarios   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model gamificacao_usuario {
  id        String   @id
  userId    String   @unique
  xp        Int      @default(0)
  nivel     Int      @default(1)
  streak    Int      @default(0)
  badges    String[] @default([])
  ranking   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime
  usuarios  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

/// Cobrança Pix emitida por um PSP (Fase N emissão; Fase O webhook; Fase Q: campo `provider`).
model PixCobranca {
  id                 String             @id @default(cuid())
  userId             String
  linkedEntityType   String
  linkedEntityId     String
  amount             Decimal            @db.Decimal(10, 2)
  /// PSP emissor (ex.: EFI). Taxas líquidas/brutas: futuro quando a API do PSP informar valores confiáveis.
  provider           String             @default("EFI")
  status             String             @default("ATIVA")
  /// Fase S.3 — Observabilidade financeira do provedor.
  /// grossAmount: valor bruto confirmado como pago (valor do webhook; fonte: PSP).
  /// providerFeeAmount: tarifa PSP — null até fonte confiável (API Efí não retorna no payload Pix).
  /// netAmount: valor líquido = gross - fee — null enquanto fee for null.
  /// providerFeeCurrency: moeda da tarifa (padrão BRL).
  /// providerFeeSource: origem do dado de tarifa — ex: efi_pix_payload, efi_financial_report, manual_reconciliation.
  /// providerFeeCapturedAt: quando o dado de tarifa foi capturado.
  grossAmount        Decimal?           @db.Decimal(12, 4)
  providerFeeAmount  Decimal?           @db.Decimal(12, 4)
  netAmount          Decimal?           @db.Decimal(12, 4)
  providerFeeCurrency String?           @default("BRL")
  providerFeeSource  String?
  providerFeeCapturedAt DateTime?
  txid               String             @unique
  endToEndId         String?            @unique
  providerReference  String?
  pixCopiaECola      String?            @db.Text
  qrCodePix          String?            @db.Text
  expiresAt          DateTime
  paidAt             DateTime?
  idempotencyKey     String             @unique
  rawProviderPayload Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEvents      PixWebhookEvent[]
  accountDeposit     AccountDeposit?

  @@index([userId, linkedEntityType, linkedEntityId])
  @@map("pix_cobrancas")
}

/// Evento recebido do webhook Pix (PSP; hoje Efí). Idempotência por idempotencyKey (ex.: endToEndId).
model PixWebhookEvent {
  id                 String       @id @default(cuid())
  idempotencyKey     String       @unique
  txid               String?
  endToEndId         String?
  amountReceived     String?
  processingResult   String
  pixCobrancaId      String?
  /// Origem operacional do evento: webhook_auto, recovery ou internal_test.
  source             String?
  requestPath        String?
  requestMethod      String?
  httpStatus         Int?
  receivedAt         DateTime?
  providerEventId    String?
  /// Resultado do settlement (negócio) associado ao mesmo webhook Pix.
  settlementResult  String?
  settlementAt       DateTime?
  metadata           Json?
  createdAt          DateTime     @default(now())
  pixCobranca        PixCobranca? @relation(fields: [pixCobrancaId], references: [id], onDelete: SetNull)

  @@index([txid])
  @@index([endToEndId])
  @@index([pixCobrancaId])
  @@index([source, receivedAt])
  @@index([providerEventId])
  @@map("pix_webhook_events")
}

// --- KYC / identidade (documental). User.isVerificado = apenas e-mail (ADR Fatia 3). ---

enum IdentityReviewStatus {
  NONE
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED_RESUBMISSION
}

enum IdentitySubmissionStatus {
  DRAFT
  PENDING_UPLOADS
  READY_FOR_REVIEW
  UNDER_MANUAL_REVIEW
  APPROVED
  REJECTED
  RESUBMISSION_REQUIRED
}

enum IdentityArtifactType {
  DOCUMENT_FRONT
  DOCUMENT_BACK
  SELFIE_PORTRAIT
}

enum IdentityArtifactUploadStatus {
  AWAITING_UPLOAD
  UPLOAD_CONFIRMED
  QUARANTINED
  DELETED_AFTER_POLICY
}

model IdentitySubmission {
  id                         String                     @id @default(cuid())
  userId                     String
  status                     IdentitySubmissionStatus   @default(DRAFT)
  versionOrAttempt           Int                        @default(1)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  submittedForReviewAt       DateTime?
  decidedAt                  DateTime?
  decisionActorType          String?
  decisionActorId            String?
  rejectReasonCode           String?
  userFacingMessageSanitized String?

  user                        User                             @relation("UserIdentitySubmissions", fields: [userId], references: [id], onDelete: Cascade)
  userPointingLastSubmission  User?                            @relation("UserLastIdentitySubmission")
  artifacts                   IdentitySubmissionArtifact[]

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([status, submittedForReviewAt])
  @@map("identity_submissions")
}

model IdentitySubmissionArtifact {
  id              String                       @id @default(cuid())
  submissionId    String
  type            IdentityArtifactType
  uploadStatus    IdentityArtifactUploadStatus @default(AWAITING_UPLOAD)
  bucket          String
  objectKey       String                       @unique
  storageProvider String                       @default("S3_COMPAT")
  mimeType        String?
  byteSize        Int?
  checksumSHA256  String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  submission IdentitySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, type])
  @@map("identity_submission_artifacts")
}

// --- Proposta temporária de abertura de conta (F1 — sem User/conta bancária até finalize) ---

enum AccountApplicationStatus {
  DRAFT
  DATA_RECEIVED
  DOCUMENTS_PENDING
  READY_TO_FINALIZE
  FINALIZED
  EXPIRED
  CANCELLED
}

model AccountApplication {
  id                    String                   @id @default(cuid())
  status                AccountApplicationStatus @default(DRAFT)
  /// Protocolo opaco exibível ao cliente (sem PII).
  protocolNumber        String                   @unique
  /// HMAC-SHA256 do token de onboarding; nunca persistir token em claro.
  tokenHash             String
  tokenExpiresAt        DateTime
  expiresAt             DateTime
  nomeCompleto          String?
  email                 String?
  cpf                   String?
  telefone              String?
  dataNascimento        DateTime?
  senhaHash             String?
  aceitaTermos          Boolean                  @default(false)
  aceitaComunicacoes    Boolean                  @default(false)
  enderecoJson          Json?
  dadosProfissionaisJson Json?
  finalizedAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([tokenHash])
  @@index([cpf, status])
  @@index([email, status])
  @@map("account_applications")
}

